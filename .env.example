# Database
DATABASE_URL=postgresql://user:password@localhost:5432/avt_auto

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me
JWT_EXPIRES_IN_DAYS=30
OTP_RESEND_SECONDS=60
OTP_TTL_SECONDS=300

# SMS delivery
# console - log codes to server console (good for local development)
# webhook - POST { phone, code, message } to your SMS bridge
SMS_PROVIDER=console
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=

# Encar scraping mode
# If set, scraper will call this Vercel endpoint instead of direct api.encar.com.
# Example: https://encar-proxy-vercel.vercel.app/api/proxy
ENCAR_PROXY_URL=

# Optional: Carapis key (only for standalone tests/tools)
CARAPIS_API_KEY=
